{
  "service": "Marketplace Platforms",
  "steps": [
    {
      "id": "project_type",
      "question": "What kind of marketplace?",
      "type": "single",
      "options": [
        { "value": "ecommerce", "label": "E-commerce", "icon": "🛍️" },
        { "value": "services", "label": "Services", "icon": "💼" },
        { "value": "digital", "label": "Digital Products", "icon": "📦" },
        { "value": "rental", "label": "Rentals", "icon": "🏠" }
      ]
    },
    {
      "id": "stage",
      "question": "What stage are you at?",
      "type": "single",
      "options": [
        { "value": "idea", "label": "Just an idea", "icon": "💡" },
        { "value": "mvp", "label": "Building MVP", "icon": "🏗️" },
        { "value": "scaling", "label": "Scaling existing product", "icon": "📈" },
        { "value": "rebuild", "label": "Rebuilding / Migrating", "icon": "🔄" }
      ]
    },
    {
      "id": "budget",
      "question": "What is your estimated budget?",
      "type": "single",
      "options": [
        { "value": "under_50k", "label": "Entry Level / Seed", "icon": "💰" },
        { "value": "50k_2l", "label": "CustomK – Custom Lakhs", "icon": "💰💰" },
        { "value": "above_2l", "label": "Custom Lakhs+", "icon": "💰💰💰" },
        { "value": "discuss", "label": "Let's discuss", "icon": "🤝" }
      ]
    },
    {
      "id": "timeline",
      "question": "How soon do you want to start?",
      "type": "single",
      "options": [
        { "value": "urgent", "label": "Immediately / Urgent", "icon": "🔥" },
        { "value": "1_month", "label": "Within 1 month", "icon": "📅" },
        { "value": "1_3_months", "label": "1 – 3 months", "icon": "🗓️" },
        { "value": "flexible", "label": "Flexible / Planning", "icon": "⏳" }
      ]
    },
    {
      "id": "features",
      "question": "What features do you need?",
      "type": "multi",
      "options": [
        { "value": "vendor_panel", "label": "Vendor Panel" },
        { "value": "payments", "label": "Split Payments / Escrow" },
        { "value": "search", "label": "Advanced Search / Filters" },
        { "value": "reviews", "label": "Ratings & Reviews" },
        { "value": "chat", "label": "User-Vendor Chat" },
        { "value": "admin", "label": "Master Admin Panel" }
      ]
    },
    {
      "id": "description",
      "question": "Tell us about your marketplace idea",
      "type": "textarea",
      "placeholder": "Describe your model, vendors, and target audience..."
    },
    {
      "id": "contact",
      "question": "How can we reach you?",
      "type": "contact",
      "fields": ["name", "email", "phone", "company"]
    }
  ]
}
